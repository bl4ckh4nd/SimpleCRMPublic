{
  "name": "simplecrm",
  "version": "0.1.6",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:watch": "vite build --watch",
    "build:electron": "vite build",
    "build:electron:watch": "vite build --watch",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "electron:dev": "cross-env NODE_ENV=development vite --port 5173 --host --clearScreen false",
    "electron:build": "npm run build && vite build && cross-env DEBUG=electron-builder* NODE_ENV=production electron-builder",
    "electron:start": "cross-env NODE_ENV=production electron dist-electron/main.js",
    "postinstall": "node node_modules/electron/install.js && node scripts/patch-better-sqlite3.js && electron-rebuild",
    "seed-db": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/seed-database.ts",
    "seed-db:test": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/seed-database.ts --customers 100 --products 50 --yes",
    "cleanup-db": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/cleanup-database.ts",
    "cleanup-db:dry": "cross-env NODE_ENV=development ts-node --project scripts/tsconfig.json scripts/cleanup-database.ts --dry-run",
    "test:performance": "node scripts/performance-test-deals.js",
    "test:performance:simple": "node scripts/performance-test-deals-simple.js",
    "check:dangerous-defaults": "node scripts/check-dangerous-defaults.js",
    "electron:dev:debug": "cross-env NODE_ENV=development vite --port 5173 --host --clearScreen false",
    "electron:test:devtools": "npm run build && npm run build:electron && cross-env NODE_ENV=production electron dist-electron/main.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "pnpm run build && playwright test -c tests/e2e/playwright.electron.config.ts",
    "test:all": "pnpm test:coverage && pnpm test:e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --selectProjects unit integration",
    "test:electron": "jest --testMatch='**/__tests__/electron/**/*.test.ts'",
    "test:frontend": "jest --testMatch='**/__tests__/frontend/**/*.test.tsx'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-table": "^8.21.3",
    "@types/electron": "^1.6.12",
    "@types/mssql": "^9.1.9",
    "@types/react-big-calendar": "^1.16.3",
    "autoprefixer": "^10.4.27",
    "better-sqlite3": "github:WiseLibs/better-sqlite3#v12.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-serve": "^3.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "embla-carousel-react": "8.6.0",
    "eslint": "^10.0.3",
    "input-otp": "1.4.2",
    "keytar": "^7.9.0",
    "knex": "^3.1.0",
    "lucide-react": "^0.577.0",
    "mina-scheduler": "^1.0.4",
    "mssql": "^12.2.0",
    "next-themes": "^0.4.6",
    "node": "^23.11.1",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript-eslint": "^8.57.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/keytar": "^4.4.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-tsconfig-paths": "^6.1.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.zondiac.simplecrm",
    "productName": "SimpleCRM",
    "files": [
      "dist/",
      "dist-electron/",
      "dist-electron/preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist-build"
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/app/simplecrmlogo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
